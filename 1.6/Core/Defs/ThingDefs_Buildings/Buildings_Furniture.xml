<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="FurnitureWithQualityBase">
    <defName>vt_foldingchair</defName>
    <label>vault folding chair</label>
    <description>A simple place to sit. Not very comfortable, but better than sitting on the floor.</description>
    <replaceTags>
      <li>Chair</li>
    </replaceTags>
    <uiIconPath>Things/Building/Furniture/Chairs/vt_chair_MenuIcon</uiIconPath>
    <uiIconScale>1.6</uiIconScale>
    <defaultPlacingRot>South</defaultPlacingRot>
    <graphicData>
      <texPath>Things/Building/Furniture/Chairs/vt_chair</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <shaderType>CutoutComplex</shaderType>
      <drawSize>(2.4,2.4)</drawSize>
      <damageData>
        <rectN>(0.25,0.234375,0.5,0.28125)</rectN>
        <rectS>(0.25,0.234375,0.5,0.28125)</rectS>
        <rectE>(0.28125,0.25,0.453125,0.25)</rectE>
        <rectW>(0.28125,0.25,0.453125,0.25)</rectW>
      </damageData>
      <shadowData>
        <volume>(0.18, 0.23, 0.18)</volume>
      </shadowData>
    </graphicData>
    <altitudeLayer>Building</altitudeLayer>
    <statBases>
      <MaxHitPoints>75</MaxHitPoints>
      <WorkToBuild>450</WorkToBuild>
      <Mass>3</Mass>
      <Flammability>1.0</Flammability>
      <Beauty>0</Beauty>
      <Comfort>0.6</Comfort>
    </statBases>
    <socialPropernessMatters>true</socialPropernessMatters>
    <costList>
      <Steel>10</Steel>
    </costList>
    <stuffCategories>
      <li>Fabric</li>
      <li>Leathery</li>
      <li>Metallic</li>
      <li>Woody</li>
    </stuffCategories>
    <costStuffCount>25</costStuffCount>
    <pathCost>30</pathCost>
    <designationHotKey>Misc6</designationHotKey>
    <uiOrder>2400</uiOrder>
    <fillPercent>0.20</fillPercent>
    <building>
      <isSittable>true</isSittable>
      <paintable>true</paintable>
    </building>
    <designationCategory>VaultItems</designationCategory>
    <researchPrerequisites>
      <li>VaultFurniture</li>
    </researchPrerequisites>
  </ThingDef>

