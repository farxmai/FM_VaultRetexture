<?xml version="1.0" encoding="utf-8"?>
<Patch>

  <!-- Simple furniture (Metallic only) -->

  <Operation Class="PatchOperationSequence">
    <operations>
      <li Class="PatchOperationReplace">
        <xpath>/Defs/ThingDef[ defName="VaultWardrobeA" ]/label</xpath>
        <value>
          <label>vault lockers (1x1)</label>
        </value>
      </li>
      <li Class="PatchOperationReplace">
        <xpath>/Defs/ThingDef[ defName="VaultWardrobeA" ]/graphicData</xpath>
        <value>
          <graphicData>
            <texPath>Things/Building/Furniture/Vault_DresserAE</texPath>
            <graphicClass>Graphic_Multi</graphicClass>
            <drawSize>(3.55,3.45)</drawSize>
          </graphicData>
        </value>
      </li>
      <li Class="PatchOperationAdd">
        <xpath>/Defs/ThingDef[ defName="VaultWardrobeA" ]</xpath>
        <value>
          <uiIconPath>Things/Building/Furniture/Vault_DresserAE_MenuIcon</uiIconPath>
        </value>
      </li>
      <li Class="PatchOperationReplace">
        <xpath>/Defs/ThingDef[ defName="VaultWardrobeA" ]/uiIconScale</xpath>
        <value>
          <uiIconScale>1</uiIconScale>
        </value>
      </li>
      <li Class="PatchOperationReplace">
        <xpath>/Defs/ThingDef[ defName="VaultWardrobeA" ]/uiIconOffset</xpath>
        <value>
          <uiIconOffset>(0,0)</uiIconOffset>
        </value>
      </li>
      <li Class="PatchOperationReplace">
        <xpath>/Defs/ThingDef[ defName="VaultWardrobeA" ]/stuffCategories</xpath>
        <value>
          <stuffCategories Inherit="true">
            <li>Metallic</li>
          </stuffCategories>
        </value>
      </li>
      <li Class="PatchOperationAdd">
        <xpath>/Defs/ThingDef[ defName="VaultWardrobeA" ]/building</xpath>
        <value>
          <paintable>true</paintable>
          <maxItemsInCell>4</maxItemsInCell>
        </value>
      </li>
    </operations>
  </Operation>


