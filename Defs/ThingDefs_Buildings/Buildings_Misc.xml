  <DesignatorDropdownGroupDef>
    <defName>VaultMedicalGroup</defName>
  </DesignatorDropdownGroupDef>

  <ThingDef ParentName="BuildingBase">
    <defName>VT_HospitalScreen</defName>
    <label>hospital screen</label>
    <description>A tall, impassable room divider. Must be placed near the bed. Slightly increase immunity gain speed.</description>
    <size>(2,1)</size>
    <graphicData>
      <texPath>Things/Building/Medical/Divider/VT_HospitalScreen</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <drawSize>(2.5,2.5)</drawSize>
      <shadowData>
        <volume>(0.3, 0.6, 0.3)</volume>
      </shadowData>
    </graphicData>
    <uiIconPath>Things/Building/Medical/Divider/VT_HospitalScreen_MenuIcon</uiIconPath>
    <uiIconScale>1.2</uiIconScale>
    <statBases>
      <MaxHitPoints>100</MaxHitPoints>
      <Mass>10</Mass>
      <WorkToBuild>1750</WorkToBuild>
      <Flammability>1.0</Flammability>
      <Beauty>7</Beauty>
    </statBases>
    <defaultPlacingRot>South</defaultPlacingRot>
    <blockWind>true</blockWind>
    <passability>PassThroughOnly</passability>
    <fillPercent>0.2</fillPercent>
    <costList>
      <Steel>30</Steel>
      <Cloth>20</Cloth>
    </costList>
    <building>
      <destroySound>BuildingDestroyed_Metal_Small</destroySound>
    </building>
    <minifiedDef>MinifiedThing</minifiedDef>
    <thingCategories>
      <li>BuildingsMisc</li>
    </thingCategories>
    <comps>
      <li Class="CompProperties_Facility">
        <statOffsets>
          <ImmunityGainSpeedFactor>0.05</ImmunityGainSpeedFactor>
          <SurgerySuccessChanceFactor>0.02</SurgerySuccessChanceFactor>
          <BedRestEffectiveness>0.05</BedRestEffectiveness>
        </statOffsets>
        <maxSimultaneous>1</maxSimultaneous>
        <maxDistance>3</maxDistance>
      </li>
    </comps>
    <designationHotKey>Misc6</designationHotKey>
    <designationCategory>VaultItems</designationCategory>
    <designatorDropdown>VaultMedicalGroup</designatorDropdown>
    <placeWorkers>
      <li>PlaceWorker_ShowFacilitiesConnections</li>
    </placeWorkers>
  </ThingDef>

